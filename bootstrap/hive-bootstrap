#!/bin/sh

set -eu

die() {
  printf 'hive-bootstrap: %s\n' "$1" >&2
  exit 1
}

script_path=$0
if [ -L "$script_path" ]; then
  link_target=$(readlink "$script_path")
  case "$link_target" in
    /*) script_path=$link_target ;;
    *) script_path=$(dirname -- "$script_path")/$link_target ;;
  esac
fi
script_dir=$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd -P)
pin_file="$script_dir/pin.env"
[ -r "$pin_file" ] || die "the immutable release pin is missing"
# shellcheck source=pin.env
. "$pin_file"

operator_home=${HOME:?HOME must name the operator account}
bootstrap_root=${HIVE_BOOTSTRAP_ROOT:-"$operator_home/.local/share/hive-bootstrap"}
launcher_dir=${HIVE_BOOTSTRAP_BIN_DIR:-"$operator_home/.local/bin"}
release_dir="$bootstrap_root/releases/$HIVE_BOOTSTRAP_VERSION"
binary="$release_dir/hive"
private_root="$bootstrap_root/state/$HIVE_BOOTSTRAP_VERSION"
private_home="$private_root/home"
runtime_home="$private_root/runtime"
bootstrap_namespace=$(printf '%s' "$bootstrap_root" | shasum -a 256 | awk '{print substr($1, 1, 10)}')
socket_root="/tmp/hive-bootstrap-$(id -u)-$bootstrap_namespace"
private_tmp="$socket_root/tmp"
tmux_tmp="$socket_root/tmux"

select_asset() {
  [ "$(uname -s)" = "Darwin" ] || die "the pinned release supports macOS only"
  case "$(uname -m)" in
    arm64)
      asset=hive-darwin-arm64
      artifact_arch=arm64
      checksum=$HIVE_BOOTSTRAP_DARWIN_ARM64_SHA256
      size=$HIVE_BOOTSTRAP_DARWIN_ARM64_SIZE
      ;;
    x86_64)
      asset=hive-darwin-x64
      artifact_arch=x64
      checksum=$HIVE_BOOTSTRAP_DARWIN_X64_SHA256
      size=$HIVE_BOOTSTRAP_DARWIN_X64_SIZE
      ;;
    *) die "unsupported architecture $(uname -m)" ;;
  esac
}

verify_binary() {
  select_asset
  [ -x "$binary" ] || die "the pinned binary is not installed; run hive-bootstrap install"
  actual_size=$(wc -c < "$binary" | tr -d '[:space:]')
  [ "$actual_size" = "$size" ] ||
    die "installed binary size mismatch (expected $size, got $actual_size)"
  actual_checksum=$(shasum -a 256 "$binary" | awk '{print $1}')
  [ "$actual_checksum" = "$checksum" ] ||
    die "installed binary checksum mismatch (expected $checksum, got $actual_checksum)"
  reported=$("$binary" --version 2>/dev/null || true)
  short_commit=$(printf '%s' "$HIVE_BOOTSTRAP_COMMIT" | cut -c1-7)
  expected="hive $HIVE_BOOTSTRAP_VERSION ($short_commit, $HIVE_BOOTSTRAP_BUILD_DATE, darwin-$artifact_arch)"
  [ "$reported" = "$expected" ] ||
    die "installed binary reported '$reported', expected '$expected'"
}

install_launcher() {
  tool_dir="$bootstrap_root/tool"
  mkdir -p "$tool_dir" "$launcher_dir"
  if [ ! "$script_dir/hive-bootstrap" -ef "$tool_dir/hive-bootstrap" ]; then
    cp "$script_dir/hive-bootstrap" "$tool_dir/hive-bootstrap"
  fi
  if [ ! "$pin_file" -ef "$tool_dir/pin.env" ]; then
    cp "$pin_file" "$tool_dir/pin.env"
  fi
  chmod 755 "$tool_dir/hive-bootstrap"

  launcher="$launcher_dir/hive-bootstrap"
  intended="$tool_dir/hive-bootstrap"
  if [ -e "$launcher" ] || [ -L "$launcher" ]; then
    current=$(readlink "$launcher" 2>/dev/null || true)
    [ "$current" = "$intended" ] ||
      die "refusing to replace unmanaged launcher at $launcher"
    return
  fi
  temporary="$launcher.tmp.$$"
  ln -s "$intended" "$temporary"
  /bin/mv -fh "$temporary" "$launcher"
  [ "$(readlink "$launcher" 2>/dev/null || true)" = "$intended" ] ||
    die "could not verify the installed launcher"
}

install_binary() {
  select_asset
  command -v curl >/dev/null 2>&1 || die "curl is required"
  command -v shasum >/dev/null 2>&1 || die "shasum is required"
  mkdir -p "$release_dir" "$bootstrap_root/staging"
  if [ -x "$binary" ]; then
    verify_binary
    install_launcher
    printf 'hive-bootstrap %s is already installed and verified\n' "$HIVE_BOOTSTRAP_VERSION"
    return
  fi

  staging=$(mktemp "$bootstrap_root/staging/hive.XXXXXX")
  cleanup_staging() {
    rm -f "$staging"
  }
  trap cleanup_staging EXIT INT TERM
  curl --proto '=https' --tlsv1.2 -fsSL \
    "$HIVE_BOOTSTRAP_RELEASE_BASE/$asset" -o "$staging"
  actual_size=$(wc -c < "$staging" | tr -d '[:space:]')
  [ "$actual_size" = "$size" ] ||
    die "downloaded binary size mismatch (expected $size, got $actual_size)"
  actual_checksum=$(shasum -a 256 "$staging" | awk '{print $1}')
  [ "$actual_checksum" = "$checksum" ] ||
    die "downloaded binary checksum mismatch (expected $checksum, got $actual_checksum)"
  chmod 755 "$staging"
  /bin/mv -f "$staging" "$binary"
  trap - EXIT INT TERM
  verify_binary
  install_launcher
  printf 'installed and verified hive-bootstrap %s (%s)\n' \
    "$HIVE_BOOTSTRAP_VERSION" "$actual_checksum"
}

print_pin() {
  select_asset
  printf '%s\n' \
    "version=$HIVE_BOOTSTRAP_VERSION" \
    "tag=$HIVE_BOOTSTRAP_TAG" \
    "commit=$HIVE_BOOTSTRAP_COMMIT" \
    "asset=$asset" \
    "sha256=$checksum" \
    "size=$size"
}

prepare_environment() {
  mkdir -p \
    "$private_home" \
    "$runtime_home" \
    "$private_tmp" \
    "$tmux_tmp" \
    "$private_home/.config" \
    "$private_home/.cache" \
    "$private_home/.local/share" \
    "$private_home/.local/state"
  chmod 700 \
    "$private_root" \
    "$private_home" \
    "$runtime_home" \
    "$socket_root" \
    "$private_tmp" \
    "$tmux_tmp"
}

print_environment() {
  prepare_environment
  printf '%s\n' \
    "HOME=$private_home" \
    "HIVE_HOME=$runtime_home" \
    "HIVE_PORT=0" \
    "TMPDIR=$private_tmp" \
    "TMUX_TMPDIR=$tmux_tmp" \
    "XDG_CONFIG_HOME=$private_home/.config" \
    "XDG_CACHE_HOME=$private_home/.cache" \
    "XDG_DATA_HOME=$private_home/.local/share" \
    "XDG_STATE_HOME=$private_home/.local/state"
}

refuse_runtime_escape() {
  for argument in "$@"; do
    case "$argument" in
      --instance|--instance=*)
        die "--instance is disabled because the bootstrap has exactly one runtime namespace"
        ;;
    esac
  done
  case "${1:-}" in
    update|uninstall)
      die "$1 is disabled for the immutable bootstrap release"
      ;;
  esac
}

run_hive() {
  refuse_runtime_escape "$@"
  verify_binary
  prepare_environment
  HOME=$private_home \
  HIVE_HOME=$runtime_home \
  HIVE_PORT=0 \
  TMPDIR=$private_tmp \
  TMP=$private_tmp \
  TEMP=$private_tmp \
  TMUX_TMPDIR=$tmux_tmp \
  XDG_CONFIG_HOME=$private_home/.config \
  XDG_CACHE_HOME=$private_home/.cache \
  XDG_DATA_HOME=$private_home/.local/share \
  XDG_STATE_HOME=$private_home/.local/state \
    exec "$binary" "$@"
}

case "${1:-}" in
  install)
    [ "$#" -eq 1 ] || die "install accepts no arguments"
    install_binary
    ;;
  verify)
    [ "$#" -eq 1 ] || die "verify accepts no arguments"
    verify_binary
    print_pin
    ;;
  pin)
    [ "$#" -eq 1 ] || die "pin accepts no arguments"
    print_pin
    ;;
  env)
    [ "$#" -eq 1 ] || die "env accepts no arguments"
    print_environment
    ;;
  *)
    run_hive "$@"
    ;;
esac

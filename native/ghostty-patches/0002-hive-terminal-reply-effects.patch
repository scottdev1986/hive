+    /// Routes a terminal-generated reply through the same single ordered
+    /// write callback used for host-originated input (HiveManual has no
+    /// child PTY, so this is the only channel toward the host). Mirrors
+    /// termio.backend.Backend.queueWrite's `.manual` case so replies and
+    /// input share one path and one ordering guarantee.
+    fn writePty(handler: *terminal.TerminalStream.Handler, data: [:0]const u8) void {
+        const self = fromHandler(handler);
+        switch (self.surface.core_surface.io.backend) {
+            .manual => |manual| manual.callback(manual.context, data.ptr, data.len),
+            .exec => {},
+        }
+    }
+
+    /// DA1/DA2 values match termio/stream_handler.zig's exec-mode
+    /// reportDeviceAttributes exactly (same pinned Ghostty build): VT220
+    /// level 2 conformance, ANSI color, no clipboard feature (52) because
+    /// clipboardWrite above always denies.
+    ///
+    /// KNOWN DIVERGENCE (cross-vendor review 2026-07-17, deferred with
+    /// queen's authorization, not fixed): DA3 (CSI = c) gets a default
+    /// Tertiary reply here (unit_id 0), but the pinned exec-mode
+    /// reportDeviceAttributes has no tertiary case and replies to DA3 with
+    /// nothing. This effect's signature — `fn (*Handler)
+    /// device_attributes.Attributes`, called once regardless of which DA
+    /// variant is being asked — has no way to know the request type and
+    /// suppress just the tertiary reply; only the caller (stream_terminal
+    /// .zig's reportDeviceAttributes) knows it. Matching exec-mode exactly
+    /// would mean patching that upstream file too, past ADR-0002's
+    /// six-file budget for a query xterm ctlseqs marks legacy/rare (no
+    /// mainstream TUI negotiation depends on DA3). Revisit if budget ever
+    /// allows a second Zig-side hunk, or if upstream adds a req-aware
+    /// device_attributes effect signature.
+    fn deviceAttributes(handler: *terminal.TerminalStream.Handler) terminal.device_attributes.Attributes {
+        _ = handler;
+        return .{ .secondary = .{ .firmware_version = 10 } };
+    }
+
+    /// Matches Ghostty's own `enquiry-response` config default (""),
+    /// which reportEnquiry treats as no reply.
+    fn enquiry(handler: *terminal.TerminalStream.Handler) []const u8 {
+        _ = handler;
+        return "";
+    }
+
+    /// Matches termio/stream_handler.zig's reportXtversion: identify as
+    /// the pinned Ghostty engine build, not the libghostty-vt default.
+    fn xtversion(handler: *terminal.TerminalStream.Handler) []const u8 {
+        _ = handler;
+        return "ghostty " ++ build_config.version_string;
+    }
+
+    /// Reports the surface's real cell geometry (never guessed) for
+    /// XTWINOPS size queries (CSI 14/16/18 t).
+    fn sizeReport(handler: *terminal.TerminalStream.Handler) ?terminal.size_report.Size {
+        const self = fromHandler(handler);
+        const grid = self.surface.core_surface.size.grid();
+        const cell = self.surface.core_surface.size.cell;
+        return .{
+            .rows = grid.rows,
+            .columns = grid.columns,
+            .cell_width = cell.width,
+            .cell_height = cell.height,
+        };
+    }
